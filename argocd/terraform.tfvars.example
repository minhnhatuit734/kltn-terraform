# KLTN ArgoCD Terraform variables example
# Copy this file to terraform.tfvars before running Terraform:
# cp terraform.tfvars.example terraform.tfvars

aws_region        = "ap-southeast-1"
availability_zone = "ap-southeast-1a"

project_name = "kltn-argocd"

vpc_cidr    = "10.10.0.0/16"
subnet_cidr = "10.10.1.0/24"

instance_type = "t2.micro"
volume_size   = 30

key_name        = "kltn-argocd-key"
public_key_path = "~/.ssh/kltn-argocd.pub"

# Demo setting:
# For KLTN demo, 0.0.0.0/0 is convenient.
# For better security, replace with your public IP, for example:
# allowed_ssh_cidr = "113.xxx.xxx.xxx/32"

allowed_ssh_cidr      = "0.0.0.0/0"
allowed_k8s_api_cidr  = "0.0.0.0/0"
allowed_web_cidr      = "0.0.0.0/0"
allowed_nodeport_cidr = "0.0.0.0/0"